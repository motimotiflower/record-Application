<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/_cat_edit"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container_cat_textview"
        android:name="com.example.sample3.Todo.edit.fragment.Fragment_Textview_Todo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="300dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout="@layout/cat_edit_textview_fragment" />

    <Button
        android:id="@+id/button_cat_edit_decide"
        android:layout_width="0dp"
        android:layout_height="99dp"
        android:layout_marginStart="110dp"
        android:layout_marginTop="24dp"
        android:text="@string/decide"
        app:layout_constraintEnd_toEndOf="@+id/fragment_container_cat_textview"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintTop_toBottomOf="@+id/fragment_container_cat_textview" />

</androidx.constraintlayout.widget.ConstraintLayout>